{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mumega.com/editorial/schemas/research-packet.schema.json",
  "title": "Editorial research packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "canonical_slug",
    "claims",
    "counterevidence",
    "normalized_entities",
    "forbidden_claims",
    "artifacts"
  ],
  "properties": {
    "contract_version": {
      "const": "1.0.0"
    },
    "canonical_slug": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim",
          "claim_type",
          "source_url",
          "evidence_reference",
          "publisher",
          "published_at",
          "accessed_at",
          "version_environment",
          "confidence",
          "uncertainty",
          "stale_trigger",
          "target_section"
        ],
        "properties": {
          "claim": {
            "type": "string",
            "minLength": 1
          },
          "claim_type": {
            "enum": ["observed", "sourced-fact", "calculation", "interpretation", "opinion"]
          },
          "source_url": {
            "anyOf": [
              {
                "type": "string",
                "format": "uri"
              },
              {
                "type": "null"
              }
            ]
          },
          "evidence_reference": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "null"
              }
            ]
          },
          "publisher": {
            "type": "string",
            "minLength": 1
          },
          "published_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ]
          },
          "accessed_at": {
            "type": "string",
            "format": "date"
          },
          "version_environment": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "null"
              }
            ]
          },
          "confidence": {
            "enum": ["high", "medium", "low"]
          },
          "uncertainty": {
            "type": "string",
            "minLength": 1
          },
          "stale_trigger": {
            "type": "string",
            "minLength": 1
          },
          "target_section": {
            "type": "string",
            "minLength": 1
          }
        },
        "anyOf": [
          {
            "properties": {
              "source_url": {
                "type": "string",
                "format": "uri"
              }
            }
          },
          {
            "properties": {
              "evidence_reference": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      }
    },
    "counterevidence": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "normalized_entities": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_claims": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifacts": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "format": "uri"
      }
    }
  }
}
