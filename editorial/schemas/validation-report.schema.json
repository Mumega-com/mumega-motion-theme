{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mumega.com/editorial/schemas/validation-report.schema.json",
  "title": "Editorial validation report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "canonical_slug",
    "role",
    "state_transition",
    "timestamp",
    "artifact_hashes",
    "gate_results",
    "unresolved_risks",
    "next_allowed_role",
    "overall_status"
  ],
  "properties": {
    "contract_version": {
      "const": "1.0.0"
    },
    "canonical_slug": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "role": {
      "$ref": "#/$defs/role"
    },
    "state_transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": {
          "anyOf": [
            {
              "$ref": "#/$defs/state"
            },
            {
              "type": "null"
            }
          ]
        },
        "to": {
          "$ref": "#/$defs/state"
        }
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "artifact_hashes": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9._-]*$"
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      }
    },
    "gate_results": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate", "status", "details"],
        "properties": {
          "gate": {
            "enum": ["schema", "scope-duplication", "evidence", "template", "wordpress", "discovery", "human"]
          },
          "status": {
            "enum": ["pass", "fail"]
          },
          "details": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "unresolved_risks": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_allowed_role": {
      "$ref": "#/$defs/role"
    },
    "overall_status": {
      "enum": ["pass", "fail"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "gate_results": {
            "type": "array",
            "contains": {
              "type": "object",
              "required": ["status"],
              "properties": {
                "status": {
                  "const": "fail"
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "overall_status": {
            "const": "fail"
          }
        }
      }
    }
  ],
  "$defs": {
    "role": {
      "enum": [
        "scout",
        "brief-creator",
        "researcher",
        "writer",
        "technical-verifier",
        "discovery-reviewer",
        "editor-handoff",
        "human-editor"
      ]
    },
    "state": {
      "enum": [
        "idea",
        "brief_ready",
        "brief_accepted",
        "research_ready",
        "research_accepted",
        "drafting",
        "technical_verification",
        "discovery_review",
        "human_review",
        "approved",
        "published",
        "update_due",
        "corrected",
        "retired"
      ]
    }
  }
}
