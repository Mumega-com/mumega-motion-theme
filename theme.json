{
  "$schema": "https://schemas.wp.org/wp/6.5/theme.json",
  "version": 2,
  "settings": {
    "layout": {
      "contentSize": "760px",
      "wideSize": "1240px"
    },
    "color": {
      "palette": [
        {
          "name": "Paper",
          "slug": "paper",
          "color": "#f7f3ea"
        },
        {
          "name": "Ink",
          "slug": "ink",
          "color": "#171717"
        },
        {
          "name": "Muted Ink",
          "slug": "muted-ink",
          "color": "#5f5b55"
        },
        {
          "name": "Lavender",
          "slug": "lavender",
          "color": "#d8cdf7"
        },
        {
          "name": "Lavender Ink",
          "slug": "lavender-ink",
          "color": "#6545a4"
        },
        {
          "name": "Rule",
          "slug": "rule",
          "color": "#cbc4b8"
        },
        {
          "name": "White",
          "slug": "white",
          "color": "#ffffff"
        }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "Iowan Old Style, Baskerville, Times New Roman, serif",
          "name": "Editorial Serif",
          "slug": "editorial-serif"
        },
        {
          "fontFamily": "Inter, ui-sans-serif, system-ui, sans-serif",
          "name": "Editorial Sans",
          "slug": "editorial-sans"
        }
      ],
      "fontSizes": [
        {
          "fluid": false,
          "name": "Small",
          "size": "0.875rem",
          "slug": "small"
        },
        {
          "fluid": {
            "min": "1rem",
            "max": "1.125rem"
          },
          "name": "Body",
          "size": "1.125rem",
          "slug": "body"
        },
        {
          "fluid": {
            "min": "1.125rem",
            "max": "1.35rem"
          },
          "name": "Lead",
          "size": "1.35rem",
          "slug": "lead"
        },
        {
          "fluid": {
            "min": "1.625rem",
            "max": "2.5rem"
          },
          "name": "Section",
          "size": "2.5rem",
          "slug": "section"
        },
        {
          "fluid": {
            "min": "2.5rem",
            "max": "5.5rem"
          },
          "name": "Display",
          "size": "5.5rem",
          "slug": "display"
        }
      ]
    }
  }
}
